      "versionNonce": 1559075425,
      "isDeleted": false,
      "boundElements": [],
      "updated": 1783871695182,
      "link": null,
      "locked": false,
      "text": "Longueur du bloc\na allouer.\nAttention on ne\npeux pas allouer\njuste 100octets,\nmmap fonction\npar plage.",
